# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Storage Paths
PLAINTABLES_PATH=./fs/plaintables
VECTOR_STORES_PATH=./fs/vector_stores
UPLOADS_PATH=./uploads

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50
